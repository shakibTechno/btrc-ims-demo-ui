{
  "version": 8,
  "name": "Clean Bangladesh",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://v3"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#d4e9f7" }
    },
    {
      "id": "land",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": { "fill-color": "#eae6df", "fill-opacity": 1 }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": { "fill-color": "#d8ecbf", "fill-opacity": 0.8 }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#b8dca0", "fill-opacity": 0.9 }
    },
    {
      "id": "landcover-crop",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "crop"],
      "paint": { "fill-color": "#dde8c4", "fill-opacity": 0.8 }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "residential", "suburb"],
      "paint": { "fill-color": "#e8e0d8", "fill-opacity": 0.8 }
    },
    {
      "id": "landuse-urban",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "commercial", "industrial"],
      "paint": { "fill-color": "#ddd8d0", "fill-opacity": 0.8 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#5ba8d4" }
    },
    {
      "id": "waterway-river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["in", "class", "river", "canal"],
      "paint": {
        "line-color": "#5ba8d4",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          5, 1.2, 8, 3.0, 12, 6.0
        ]
      }
    },
    {
      "id": "waterway-stream",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["in", "class", "stream", "drain", "ditch"],
      "paint": {
        "line-color": "#7ec0e0",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8, 0.6, 12, 2.5
        ]
      }
    },
    {
      "id": "boundary-admin",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": { "line-color": "#b0bec8", "line-width": 0.8, "line-dasharray": [4, 2] }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": { "line-color": "#7a9aaa", "line-width": 1.8 }
    }
  ]
}
